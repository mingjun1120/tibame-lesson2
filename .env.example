# 本檔為 infra + api + web 共享的環境變數，放在 repo 根目錄。
# 第一次：cp .env.example .env 後按需修改。
#
# ⚠️ 安全鐵律：只有 `VITE_` 前綴的變數會被打包進前端 bundle、等同公開資訊。
# 機敏值（JWT_SECRET、COOKIE_SECRET、DATABASE_URL、密碼等）絕不可加 VITE_ 前綴，
# 也絕不可放進任何前端讀得到的位置。前端的讀取邊界已在 vite.config.ts 鎖死。

# Database
DATABASE_URL=postgresql://vms:vms@localhost:5432/vms?schema=public

# API
API_PORT=8090
WEB_ORIGIN=http://localhost:3087

# Web (Vite dev server)
WEB_PORT=3087
# Vite /api proxy 目標，需對齊 API_PORT
API_TARGET=http://localhost:8090

# Auth
JWT_SECRET=replace-me-with-a-32-byte-random-string
JWT_EXPIRES_IN=8h
COOKIE_SECRET=replace-me-with-another-random-string

# Seed
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin12345

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
